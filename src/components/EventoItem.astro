---
interface Props {
  title: string;
  description: string;
  startDate: string;
  endDate: string;
  location?: string;
  category: string;
}

const { title, description, startDate, endDate, location, category } = Astro.props;

const start = new Date(startDate);
const day = start.getDate();
const month = start.toLocaleDateString('es-CO', { month: 'short' }).toUpperCase();

const categoryColors: Record<string, string> = {
  Institucional: 'var(--brand-navy)',
  Capacitacion: 'var(--brand-blue)',
  Bienestar: 'var(--theme-success)',
  Reunion: 'var(--theme-warning)',
  Otro: 'var(--theme-text-secondary)',
};
---

<article class="evento-item">
  <div class="evento-date" style={`border-color: ${categoryColors[category] ?? 'var(--theme-accent)'}`}>
    <span class="evento-day">{day}</span>
    <span class="evento-month">{month}</span>
  </div>
  <div class="evento-body">
    <div class="evento-header">
      <span class="evento-category" style={`color: ${categoryColors[category] ?? 'var(--theme-accent)'}`}>{category}</span>
    </div>
    <h4 class="evento-title">{title}</h4>
    <p class="evento-desc">{description}</p>
    {location && (
      <p class="evento-location">
        <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
        {location}
      </p>
    )}
  </div>
</article>

<style>
  .evento-item {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--theme-border-light);
  }

  .evento-item:last-child {
    border-bottom: none;
  }

  .evento-date {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px solid;
    border-radius: var(--radius-md);
    background: var(--theme-bg-surface);
  }

  .evento-day {
    font-size: var(--font-size-xl);
    font-weight: 700;
    line-height: 1;
    color: var(--theme-text-primary);
  }

  .evento-month {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--theme-text-secondary);
  }

  .evento-header {
    margin-bottom: 2px;
  }

  .evento-category {
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
  }

  .evento-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--theme-text-primary);
  }

  .evento-desc {
    font-size: var(--font-size-sm);
    color: var(--theme-text-secondary);
    margin-top: 2px;
    line-height: 1.4;
  }

  .evento-location {
    font-size: var(--font-size-xs);
    color: var(--theme-text-muted);
    margin-top: var(--space-xs);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
</style>
