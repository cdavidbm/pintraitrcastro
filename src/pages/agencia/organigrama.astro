---
import SectionPage from '@layouts/SectionPage.astro';
---

<SectionPage title="Organigrama" breadcrumbs={[{ label: 'Agencia', href: '/agencia' }, { label: 'Organigrama' }]}>
  <p class="section-intro">
    Estructura organizacional de la Agencia del Inspector General de Tributos, Rentas y Contribuciones Parafiscales.
  </p>

  <div class="organigrama-placeholder">
    <i class="fa-solid fa-sitemap" aria-hidden="true"></i>
    <p>El organigrama institucional sera publicado proximamente.</p>
  </div>
</SectionPage>

<style>
  .section-intro {
    color: var(--theme-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-xl);
    max-width: 72ch;
  }

  .organigrama-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-2xl);
    background: var(--theme-bg-surface);
    border: 2px dashed var(--theme-border-light);
    border-radius: var(--radius-lg);
    color: var(--theme-text-muted);
    text-align: center;
  }

  .organigrama-placeholder i {
    font-size: 3rem;
    opacity: 0.4;
  }
</style>
