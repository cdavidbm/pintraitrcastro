---
import SectionPage from '@layouts/SectionPage.astro';
import AnuncioCard from '@components/AnuncioCard.astro';

interface AnuncioFrontmatter {
  title: string;
  date: string;
  category: string;
  excerpt: string;
  featured?: boolean;
  display_mode: string;
}

const allPosts = import.meta.glob<{ frontmatter: AnuncioFrontmatter }>('../../content/anuncios/*.md', { eager: true });

const noticias = Object.entries(allPosts)
  .map(([path, mod]) => {
    const slug = path.split('/').pop()?.replace('.md', '') ?? '';
    return { slug, ...mod.frontmatter };
  })
  .filter((a) => a.display_mode === 'visible')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<SectionPage title="Noticias" breadcrumbs={[{ label: 'Prensa', href: '/prensa' }, { label: 'Noticias' }]}>
  <div class="noticias-list">
    {noticias.length > 0 ? (
      noticias.map((n) => (
        <AnuncioCard
          title={n.title}
          date={n.date}
          category={n.category}
          excerpt={n.excerpt}
          slug={n.slug}
          featured={n.featured}
        />
      ))
    ) : (
      <p class="empty-state">No hay noticias disponibles.</p>
    )}
  </div>
</SectionPage>

<style>
  .noticias-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .empty-state {
    color: var(--theme-text-muted);
    text-align: center;
    padding: var(--space-xl);
  }
</style>
