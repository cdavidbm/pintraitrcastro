---
import SectionPage from '@layouts/SectionPage.astro';
import AnuncioCard from '@components/AnuncioCard.astro';

const basePath = import.meta.env.BASE_URL;

const anuncioFiles = import.meta.glob<{
  frontmatter: {
    title: string;
    date: string;
    category: string;
    excerpt: string;
    featured: boolean;
    display_mode: string;
  };
}>('../../content/anuncios/*.md', { eager: true });

const anuncios = Object.entries(anuncioFiles)
  .map(([path, mod]) => {
    const slug = path.split('/').pop()?.replace('.md', '') ?? '';
    return { ...mod.frontmatter, slug };
  })
  .filter((a) => a.display_mode === 'visible')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<SectionPage title="Anuncios" breadcrumbs={[{ label: 'Anuncios' }]}>
  <div class="anuncios-list">
    {anuncios.length > 0 ? (
      anuncios.map((anuncio) => (
        <AnuncioCard
          title={anuncio.title}
          date={anuncio.date}
          category={anuncio.category}
          excerpt={anuncio.excerpt}
          href={`${basePath}anuncios/${anuncio.slug}`}
          featured={anuncio.featured}
        />
      ))
    ) : (
      <p class="empty-state">No hay anuncios disponibles.</p>
    )}
  </div>
</SectionPage>

<style>
  .anuncios-list {
    background: var(--theme-bg-surface);
    border: 1px solid var(--theme-border-light);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
  }

  .empty-state {
    color: var(--theme-text-muted);
    text-align: center;
    padding: var(--space-xl);
  }
</style>
